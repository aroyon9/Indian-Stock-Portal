# Compose defaults (edit as needed)

# Postgres (user DB)
POSTGRES_USER=portal
POSTGRES_PASSWORD=portal_password
POSTGRES_DB=portal_userdb

# TimescaleDB (OHLCV DB)
TIMESCALE_USER=timescale
TIMESCALE_PASSWORD=timescale_password
TIMESCALE_DB=portal_pricedb

# Backend
JWT_SECRET=change_me_in_dev
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=["http://localhost:3000"]
MOCK_DATA=false
USER_DATABASE_URL=postgresql+psycopg://portal:portal_password@localhost:5432/portal_userdb
TIMESCALE_DATABASE_URL=postgresql+psycopg://timescale:timescale_password@localhost:5433/portal_pricedb
USER_DB_ALLOW_SQLITE_FALLBACK=true
USER_DB_SOCKET_PROBE_TIMEOUT_SECONDS=1.5
USER_DB_PROBE_RETRIES=3
USER_DB_PROBE_RETRY_DELAY_SECONDS=0.4
TIMESCALE_DB_ALLOW_SQLITE_FALLBACK=true
TIMESCALE_DB_SOCKET_PROBE_TIMEOUT_SECONDS=1.5
TIMESCALE_DB_PROBE_RETRIES=3
TIMESCALE_DB_PROBE_RETRY_DELAY_SECONDS=0.4

# Frontend (used by Next.js proxy route on the server)
BACKEND_INTERNAL_URL=http://backend:8000
